# =============================================================
# Fuel Finder Backend — Environment Configuration Template
# =============================================================
# Copy this file to .env for local development:
#   cp .env.example .env
# Then fill in your actual values. NEVER commit the .env file.
# =============================================================

# -------------------------------------------------------
# Database (PostgreSQL / Supabase)
# -------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=fuel_finder
DB_USER=postgres
DB_PASSWORD=your_db_password_here
DB_SSL=false

# For Supabase (replace localhost config above):
# DB_HOST=aws-0-<region>.pooler.supabase.com
# DB_PORT=5432
# DB_NAME=postgres
# DB_USER=postgres.<your-project-ref>
# DB_PASSWORD=your_supabase_db_password
# DB_SSL=true

# Database Pool
DB_MAX_CONNECTIONS=20
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=20000

# -------------------------------------------------------
# Server
# -------------------------------------------------------
PORT=3001
NODE_ENV=development

# -------------------------------------------------------
# Cache (ms)
# -------------------------------------------------------
CACHE_TTL_MS=120000

# -------------------------------------------------------
# Rate Limiting
# -------------------------------------------------------
API_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX_REQUESTS=100

# -------------------------------------------------------
# CORS (comma-separated origins)
# -------------------------------------------------------
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# -------------------------------------------------------
# Security
# -------------------------------------------------------
# Generate a strong JWT secret: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_here
ADMIN_API_KEY=your_admin_api_key_here

# -------------------------------------------------------
# Logging
# -------------------------------------------------------
LOG_LEVEL=info
DEBUG=false

# -------------------------------------------------------
# OSRM Routing Engine
# -------------------------------------------------------
# Self-hosted or cloud OSRM instance URL
OSRM_BASE_URL=http://localhost:5000
OSRM_TIMEOUT_MS=20000

# -------------------------------------------------------
# Supabase Storage (for station images)
# -------------------------------------------------------
SUPABASE_URL=https://your-project-ref.supabase.co
# Get this from: Supabase Dashboard > Settings > API > service_role key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
SUPABASE_STORAGE_BUCKET=station-images

# -------------------------------------------------------
# Email / SMTP (Gmail example)
# -------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
# Use a Gmail App Password (not your account password)
# Generate at: https://myaccount.google.com/apppasswords
SMTP_PASS=your_16_char_app_password
SMTP_FROM="Fuel Finder <your-email@gmail.com>"

# -------------------------------------------------------
# PayMongo (Payments)
# -------------------------------------------------------
# Get from: https://dashboard.paymongo.com/developers
PAYMONGO_SECRET_KEY=sk_test_your_secret_key_here
PAYMONGO_PUBLIC_KEY=pk_test_your_public_key_here
PAYMONGO_WEBHOOK_SECRET=whsk_your_webhook_secret_here

# -------------------------------------------------------
# Twilio (SMS OTP for owner login)
# -------------------------------------------------------
# Get from: https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -------------------------------------------------------
# Health Check
# -------------------------------------------------------
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_PATH=/api/health

# -------------------------------------------------------
# App Metadata
# -------------------------------------------------------
APP_NAME=Fuel Finder API
APP_VERSION=1.0.0
APP_DESCRIPTION=Fuel station locator API with PostGIS spatial queries
