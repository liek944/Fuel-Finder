# Production Environment Configuration for Render Deployment
# Copy this to .env in production or set these as Render Web Service environment variables

# Database Configuration (Supabase PostgreSQL with SSL)
DB_HOST=aws-1-ap-southeast-1.pooler.supabase.com
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres.ycmoophkkikrltgroane
DB_PASSWORD=c5hCVCx93SB3uzHF
DB_SSL=true

# Database Pool Configuration (Production optimized)
DB_MAX_CONNECTIONS=20
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=20000

# Server Configuration
# Render sets PORT automatically; server.js uses PORT or defaults to 3001
PORT=3001
NODE_ENV=production

# Cache Configuration (5 minutes for production)
CACHE_TTL_MS=300000

# API Rate Limiting
API_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX_REQUESTS=1000

# CORS Configuration (Production domains)
ALLOWED_ORIGINS=https://fuelfinderths.netlify.app,https://fuelfinder.duckdns.org,http://localhost:3000,http://localhost:3001,https://fuel-finder-six.vercel.app/

