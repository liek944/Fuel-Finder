# Development environment configuration for Fuel Finder Frontend
# This file is used when running the app locally in development mode

# API Base URL for development
# Points to the local backend server
# NOTE: Using VITE_ prefix because this is a Vite-based React app
VITE_API_BASE_URL=http://localhost:3001

# Note: In production, this will be overridden by .env.production
# or by environment variables set in your hosting platform (Vercel, Netlify, etc.)
